// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  SUPPORT
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String  @id @default(cuid())
  Fullname      String
  email         String  @unique
  supabaseId    String  @unique
  password      String
  emailVerified Boolean @default(false)

  // RBAC — single role per user. Permissions map from role server-side
  // in `backend/src/auth/rbac.ts`. USER is the default for every new
  // signup.
  role        UserRole  @default(USER)
  // Bumped by AuditService.record on login / oauth_login. Powers the
  // admin "active in last X days" query without scanning AuditLog.
  lastLoginAt DateTime?

  // Subscription fields
  subscriptionStatus           String    @default("FREE") // "FREE" or "PRO"
  stripeCustomerId             String?   @unique
  stripeSubscriptionId         String?   @unique
  subscriptionCurrentPeriodEnd DateTime?

  // Usage tracking
  attemptsUsed Int @default(0) // Track how many attempts user has used

  notes        Note[]
  quizzes      Quiz[]
  files        File[]
  uploads      Upload[]
  jobs         Job[]
  chatSessions ChatSession[]

  @@index([role])
  @@index([lastLoginAt])
}

model Note {
  id           String        @id @default(cuid())
  title        String
  content      String
  source       String? // Optional: track source file or PDF
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  quizzes      Quiz[]
  chatSessions ChatSession[]

  @@index([userId])
  @@index([userId, createdAt])
}

model Quiz {
  id        String   @id @default(cuid())
  title     String
  questions Json
  score     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  noteId    String? // Link quiz to a note
  user      User     @relation(fields: [userId], references: [id])
  note      Note?    @relation(fields: [noteId], references: [id])
  // GIN index on the JSON column lives in a manual migration
  // (20260505_add_quiz_questions_gin_index). Prisma can't model
  // expression / functional indexes natively, so the schema notes its
  // existence here to keep the docs honest.

  @@index([userId])
  @@index([noteId])
  @@index([userId, createdAt])
}

model ChatSession {
  id        String        @id @default(cuid())
  title     String? // Optional title for the chat session
  messages  ChatMessage[]
  noteId    String? // Link chat to a note for context
  note      Note?         @relation(fields: [noteId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([noteId])
  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  role      String // 'user' or 'assistant'
  content   String
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

model File {
  id     String @id @default(cuid())
  url    String
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Uploads represent user-uploaded files (e.g. PDFs, images). This is separate
// from the existing `File` model to avoid breaking changes; you can migrate
// or consolidate later if desired.
model Upload {
  id        String   @id @default(cuid())
  url       String
  filename  String
  size      Int?
  mime      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

enum JobStatus {
  waiting
  processing
  extracting
  generating_notes
  generating_quiz
  completed
  failed
  delayed
  paused
}

// Audit log for security-sensitive actions. Used for non-repudiation:
// every entry records who did what, when, and from where.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String // e.g. 'login', 'logout', 'login_failed', 'oauth_login', 'file_delete', 'subscription_change'
  target    String? // optional: id of resource acted upon
  ip        String?
  userAgent String?
  meta      Json? // optional structured detail; never log secrets/PII payloads
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Stripe webhook idempotency. Stripe may deliver the same event more
// than once; we record event.id here on first processing and refuse
// duplicates.
model StripeEvent {
  id          String   @id // event.id from Stripe
  type        String
  processedAt DateTime @default(now())

  @@index([type])
}

// Jobs table to store metadata about BullMQ jobs. The authoritative job state
// lives in Redis, but storing job metadata here is useful for auditing,
// long-term history, relationships to users, and analytics.
model Job {
  id           String    @id @default(cuid())
  jobId        String    @unique // Bull/Bee-Queue job id (if available)
  name         String
  data         Json
  opts         Json?
  status       JobStatus @default(waiting)
  attempts     Int       @default(0)
  priority     Int?
  progress     Int?      @default(0)
  failedReason String?
  finishedAt   DateTime?
  failedAt     DateTime?
  queueName    String
  timestamp    DateTime  @default(now())
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
