# Backend environment template. Copy to `.env` and fill in real values.
# Never commit `.env` — root .gitignore blocks it.

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Database ---
# Pooled URL for application traffic (PgBouncer transaction mode in prod).
DATABASE_URL=postgresql://user:pass@host:5432/db
# Direct, non-pooled URL — used by Prisma migrations only.
DIRECT_URL=postgresql://user:pass@host:5432/db

# --- Frontend ---
# Origin used for CORS, CSP connectSrc, and SameSite cookies. No trailing slash.
FRONTEND_URL=http://localhost:5173

# --- Supabase ---
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_BUCKET_NAME=pdfs

# --- AI ---
GEMINI_API_KEY=...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...

# --- Redis (either REDIS_URL or REDIS_HOST/PORT/PASSWORD) ---
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# `true` enables TLS (Upstash, Redis Cloud). Leave blank for local Redis.
REDIS_TLS=false

# --- Optional observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Admin / RBAC ---
# Comma-separated allowlist of emails auto-promoted to ADMIN on first login.
# SUPER_ADMIN is reserved for the seed script — it never auto-promotes.
ADMIN_EMAILS=
# Credentials used by `npx prisma db seed` to create the initial SUPER_ADMIN.
# Defaults: admin@buds-ai.local / ChangeMe!Admin123 — rotate after first login.
ADMIN_SEED_EMAIL=admin@buds-ai.local
ADMIN_SEED_PASSWORD=ChangeMe!Admin123
